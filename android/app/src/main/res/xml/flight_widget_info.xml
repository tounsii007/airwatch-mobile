<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget metadata. Compact 4×2 grid cell — fits a single home-screen
  row on most launchers. updatePeriodMillis is left at 0 because the
  Flutter side pushes updates explicitly via HomeWidget.updateWidget;
  Android's auto-refresh would otherwise cap us at 30-min granularity.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="180dp"
    android:minHeight="80dp"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/flight_widget"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:previewLayout="@layout/flight_widget"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:description="@string/widget_description" />
