<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ data-extraction policy (replaces the older
    fullBackupContent scheme on API 31+). Two surfaces are configured
    distinctly:

      <cloud-backup>   — Google Drive Auto Backup. Disabled at the
                         application level via allowBackup="false";
                         the empty <include>/<exclude> blocks here are
                         a defence-in-depth restatement.

      <device-transfer> — phone-to-phone transfer when the user sets up
                         a new Android device. Same posture: nothing
                         leaves the source device automatically. Users
                         re-pair via a fresh app install.

    Tighten the policy by listing specific paths under <include>; loosen
    it by adding <exclude>. The current empty lists mean: include
    nothing, exclude nothing. Effect: no backup, no transfer.
-->
<data-extraction-rules>
    <cloud-backup />
    <device-transfer />
</data-extraction-rules>
