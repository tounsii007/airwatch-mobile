<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon (Android 8.0+, API 26).

  Splits the icon into a separately-masked background + foreground so the
  launcher can apply the device's preferred mask shape (circle, squircle,
  teardrop, etc.) without clipping the radar artwork. The bitmaps come from
  the per-density `ic_launcher_foreground.png` / `ic_launcher_background.png`
  files generated by `tool/generate_launcher_icons.dart`.

  Pre-26 devices fall back to the legacy `ic_launcher.png` files declared in
  the parent `mipmap-*` directories — they don't see this XML.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@mipmap/ic_launcher_background"/>
    <foreground android:drawable="@mipmap/ic_launcher_foreground"/>
</adaptive-icon>
