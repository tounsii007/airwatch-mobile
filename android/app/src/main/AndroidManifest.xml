<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Voice command (speech_to_text plugin) needs raw microphone
         access plus an internet permission so Google's recognizer
         can stream the audio back. Without these, the VoiceButton
         silently no-ops on real devices. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- Spotting screen needs the device's GPS to pick the 60-km
         radius around the user. We only ask for foreground precision
         (no background location) because the screen runs in the
         foreground while the user is at a runway/observation point. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>

    <!-- AR mode + camera-based spotting (existing Camera dependency).
         The Camera plugin auto-declares CAMERA, but listing it
         explicitly here makes the manifest self-documenting and
         survives plugin upgrades that may drop the auto-declare. -->
    <uses-permission android:name="android.permission.CAMERA"/>

    <!-- Local notifications (squawk + geofence alerts). VIBRATE is
         covered by the default channel; POST_NOTIFICATIONS is the
         Android 13+ runtime-permission gate that the plugin requests
         from Dart. -->
    <uses-permission android:name="android.permission.VIBRATE"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- speech_to_text on Android delegates to Google's recognizer
         service which lives in another package — Android 11+
         requires apps to declare visibility for it. -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService"/>
        </intent>
    </queries>

    <!--
      Security hardening on the <application> element:

        android:allowBackup="false"
            Disables Google Auto Backup. Without this, the geofence
            list, settings, alert read-state and any future cached
            session data would be transparently uploaded to the user's
            Google Drive when the device backs up. Auto Backup is
            convenient for stateless games — for an app that handles
            location data and admin sessions, it's a privacy-bleed
            channel that's hard to audit. We persist nothing the user
            can't recreate from a fresh install (favourites are an
            in-app re-add).

        android:dataExtractionRules="@xml/data_extraction_rules"
            Android 12+ replacement for android:fullBackupContent.
            The XML file scopes any backup that does happen
            (e.g. a manual `adb backup`) to nothing, matching the
            allowBackup=false signal.

        android:fullBackupContent="@xml/backup_rules"
            Android 11- equivalent. Same intent — empty include list.

        android:usesCleartextTraffic="false"
            Defence-in-depth: if a future config bug ever sets
            API_BASE_URL to http://, the platform refuses the request
            instead of silently downgrading. Combined with the
            release-mode guard in AppConfig.apiBaseUrl, plaintext
            traffic is blocked at two layers.
    -->
    <application
        android:label="AirWatch"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:usesCleartextTraffic="false">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Home-screen widget receiver. The Flutter side calls
             HomeWidget.updateWidget(...FlightWidgetProvider) which
             fires APPWIDGET_UPDATE at this receiver; the receiver
             reads the data the Flutter side persisted and rebuilds
             the RemoteViews. The metadata file at xml/flight_widget_info
             defines the visible cell size + initial layout.

             android:permission="android.permission.BIND_APPWIDGET" —
             defence-in-depth. Only the system AppWidget host (which
             holds this signature-level permission) can deliver the
             APPWIDGET_UPDATE intent here, blocking any local app from
             spoofing widget refreshes through `adb shell am broadcast`. -->
        <receiver
            android:name=".FlightWidgetProvider"
            android:exported="true"
            android:permission="android.permission.BIND_APPWIDGET">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/flight_widget_info" />
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
