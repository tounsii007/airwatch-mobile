# AirWatch mobile container stack — environment template.
# Copy to `.env` (gitignored) and edit to match your deployment.

# ─── Host port mappings ──────────────────────────────────────────────────
# Choose ports that don't clash with airwatch-api (18080/18090/19091) or
# airwatch-web (3000).
MOBILE_WEB_HOST_PORT=18091
PROXY_HOST_PORT=18092

# Which interface the published ports bind to. Default 127.0.0.1 keeps
# the dev preview off the LAN — only the host machine can reach it.
# Switch to 0.0.0.0 if you genuinely want LAN access (and have a TLS
# terminator in front).
PUBLISH_INTERFACE=127.0.0.1

# ─── Backend the bundle talks to ─────────────────────────────────────────
# `/api` (default) → same-origin: nginx in this container reverse-proxies
# /api/* to ${API_UPSTREAM}. Best DX, no CORS.
#
# Override to an absolute URL if you ship the bundle behind a CDN that
# can't proxy: https://api.airwatch.app/. The hosted backend MUST then
# allow this image's origin in its ALLOWED_ORIGINS.
FLUTTER_API_BASE_URL=/api

# Where nginx forwards /api/* to. Default targets the airwatch-api
# container on the shared `airwatch_airwatch-net` network.
#   airwatch-api:18090         → Spring Boot mobile port (default)
#   airwatch-proxy:8080        → the Dart sidecar (with --profile proxy)
#   http://host.docker.internal:18090 → an api running on the host
API_UPSTREAM=http://airwatch-api:18090

# ─── Dart sidecar proxy (only used with `--profile proxy`) ──────────────
# Required if you start `airwatch-proxy`; the proxy refuses to boot
# without it. Get one at https://airlabs.co/.
# AIRLABS_KEY=replace-me
