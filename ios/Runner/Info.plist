<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>AirWatch</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>AirWatch</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- Voice-command button (speech_to_text) needs both keys on iOS.
	     Without them the system never asks for permission and the
	     button silently no-ops. The strings are user-facing in the
	     iOS permission dialog. -->
	<key>NSMicrophoneUsageDescription</key>
	<string>AirWatch listens to your voice command (e.g. "show flight DLH123") to control the map. Audio is processed by your device's speech recognizer and never stored.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>AirWatch turns spoken commands into map actions like opening a flight or switching the basemap. The transcript is parsed locally; no audio leaves the device beyond the system recognizer.</string>
	<!-- Spotting screen + map-centering use the device GPS to find
	     aircraft within 60 km of the user. Foreground-only — we
	     never request "Always" because the screen needs to be open
	     for the radius ring to be useful. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>AirWatch uses your location to centre the map on you and to find aircraft within a 60 km radius for spotting. Your location is never sent to a server or stored.</string>
	<!-- AR mode points the camera at the sky and overlays nearby
	     flights — the camera frame is processed entirely on-device. -->
	<key>NSCameraUsageDescription</key>
	<string>AirWatch uses the camera in AR mode to overlay nearby aircraft on the live sky view. Frames are processed on-device and never uploaded.</string>
	<!-- Sensor access for AR's heading + tilt readout. iOS surfaces
	     this prompt the first time the AR screen tries to read the
	     compass. -->
	<key>NSMotionUsageDescription</key>
	<string>AirWatch reads your device's compass + tilt sensors so the AR sky view can align aircraft icons with the real horizon and bearing.</string>
</dict>
</plist>
