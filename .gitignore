# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Proxy cache files (persist between restarts, not in VCS)
proxy/cache/*.json
proxy/cache/*.notfound
proxy/certs/*.pem

# Release signing — never commit real keystore material. CI injects the
# upload key from secrets and writes a temporary key.properties; locally,
# devs copy key.properties.example → key.properties and fill in the values.
android/key.properties
android/app/upload-keystore.jks
android/app/keystore.jks
*.jks
*.keystore

# Compose .env auto-loads in `docker compose up`. We never commit it —
# it can hold the AIRLABS_KEY for the proxy sidecar, the Play Store
# service-account JSON path, or any other operator secret. The
# template lives at .env.example.
.env
.env.local
.env.*.local
